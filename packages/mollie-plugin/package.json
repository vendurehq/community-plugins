{
    "name": "@vendure-community/mollie-plugin",
    "version": "1.0.0",
    "license": "GPL-3.0-or-later",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "files": [
        "lib/**/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/vendurehq/community-plugins",
        "directory": "packages/mollie-plugin"
    },
    "private": false,
    "scripts": {
        "watch": "tsc -p ./tsconfig.build.json --watch",
        "build": "rimraf lib && tsc -p ./tsconfig.build.json",
        "e2e": "cross-env PACKAGE=mollie-plugin vitest --config ../../e2e-common/vitest.config.mts --run",
        "e2e:watch": "cross-env PACKAGE=mollie-plugin vitest --config ../../e2e-common/vitest.config.mts",
        "lint": "eslint .",
        "ci": "npm run build",
        "dev-server": "npm run build && DB=sqlite node -r ts-node/register e2e/mollie-dev-server.ts"
    },
    "homepage": "https://www.vendure.io/",
    "funding": "https://github.com/sponsors/michaelbromley",
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@vendure/core": "^3.6.0-0",
        "@vendure/common": "^3.6.0-0",
        "@mollie/api-client": "4.x"
    },
    "dependencies": {
        "currency.js": "2.0.4"
    },
    "devDependencies": {
        "@mollie/api-client": "^4.3.3",
        "@vendure/common": "3.6.0-minor-202603280303",
        "@vendure/core": "3.6.0-minor-202603280303",
        "@vendure/testing": "3.6.0-minor-202603280303",
        "nock": "^13.1.4",
        "rimraf": "^5.0.5",
        "typescript": "5.8.2"
    }
}
